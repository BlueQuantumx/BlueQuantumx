{
	"folders": [
		{
			"path": ".."
		},
		{
			"path": "../Articles"
		}
	],
	"settings": {
		"files.exclude": {
			"**/_v*": true
		},
		"code-runner.clearPreviousOutput": true,
		"code-runner.executorMapByFileExtension": {
			".md": "pandoc --mathml $fileName -o ./Exports/$fileNameWithoutExt.html --template=../Resources/MyTemplate.html -M pagetitle=$fileNameWithoutExt"
		}
	}
}